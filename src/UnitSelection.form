<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="UnitSelection">
  <grid id="27dc6" binding="MainPanel" layout-manager="GridLayoutManager" row-count="3" column-count="4" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="500" height="177"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <component id="6d485" class="javax.swing.JLabel" binding="subTitle">
        <constraints>
          <grid row="1" column="0" row-span="1" col-span="4" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="16"/>
          <text value="What unit system do you prefer?"/>
        </properties>
      </component>
      <component id="2ad5a" class="javax.swing.JLabel" binding="title">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="4" vsize-policy="0" hsize-policy="0" anchor="0" fill="0" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font name="JetBrains Mono" size="24" style="1"/>
          <horizontalAlignment value="10"/>
          <horizontalTextPosition value="11"/>
          <text value="BMI Calculator"/>
        </properties>
      </component>
      <component id="8ae85" class="javax.swing.JButton" binding="metricBtn">
        <constraints>
          <grid row="2" column="1" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="16"/>
          <text value="Metric Units"/>
        </properties>
      </component>
      <component id="630" class="javax.swing.JButton" binding="englishBtn">
        <constraints>
          <grid row="2" column="2" row-span="1" col-span="1" vsize-policy="0" hsize-policy="3" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <font size="16"/>
          <text value="English Units"/>
        </properties>
      </component>
      <hspacer id="225b8">
        <constraints>
          <grid row="2" column="0" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
      </hspacer>
      <hspacer id="54f30">
        <constraints>
          <grid row="2" column="3" row-span="1" col-span="1" vsize-policy="1" hsize-policy="6" anchor="0" fill="1" indent="0" use-parent-layout="false"/>
        </constraints>
      </hspacer>
    </children>
  </grid>
</form>
